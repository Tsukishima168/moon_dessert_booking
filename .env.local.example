# Supabase 設定
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Resend Email API（用於寄信給客戶）
RESEND_API_KEY=re_your_api_key_here
# 寄件人 Email（需要在 Resend 驗證）
RESEND_FROM_EMAIL=orders@yourdomain.com

# LINE Notify Token（用於接收訂單通知）
LINE_NOTIFY_TOKEN=your_line_notify_token_here

# 匯款資訊（顯示給客戶）
BANK_NAME=連線商業銀行
BANK_CODE=824
BANK_BRANCH=總行 6880
BANK_ACCOUNT=111007479473
ACCOUNT_HOLDER=您的名字

# 店家聯絡資訊
STORE_NAME=MoonMoon Dessert
STORE_PHONE=0912-345-678
STORE_LINE_ID=@moonmoon

# Cron Job 驗證密鑰（Vercel 部署時自動設定）
# 本地測試可設定任意值，生產環境 Vercel 會自動處理
CRON_SECRET=your-cron-secret-here

# Admin 後台密碼（簡易保護）
ADMIN_PASSWORD=admin123

# Google Analytics 4 追蹤 ID（選填）
# 取得方式：https://analytics.google.com → 管理 → 資料串流 → 評估 ID
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX


