# Supabase 設定
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Resend Email API（用於寄信給客戶）
RESEND_API_KEY=re_your_api_key_here
# 寄件人 Email（需要在 Resend 驗證）
RESEND_FROM_EMAIL=orders@yourdomain.com

# Discord 訂單通知
# 與 map / menu 共用「Kiwimu宇宙 → #月島訂單通知」頻道，shop 以來源標籤區分。
# 接法 A（建議，與 map/menu 相同）：Bot Token 直接發到頻道
#   取得：Discord Developer Portal → 你的 App → Bot → Reset/Copy Token（與 map 同一個 bot）
DISCORD_TOKEN=your-discord-bot-token
DISCORD_ORDER_CHANNEL_ID=1467024414699819152
# 來源標籤（選填，預設「線上商店 shop.kiwimu.com」）
# DISCORD_SOURCE_LABEL=線上商店 shop.kiwimu.com
#
# 接法 B（fallback）：沒有 Bot Token 時改用 Webhook（頻道 → 整合 → Webhook → 新增）
DISCORD_WEBHOOK_URL=

# 匯款資訊（顯示給客戶）
BANK_NAME=your-bank-name
BANK_CODE=your-bank-code
BANK_BRANCH=your-bank-branch
BANK_ACCOUNT=your-account-number
ACCOUNT_HOLDER=your-name

# 店家聯絡資訊
STORE_NAME=MoonMoon Dessert
STORE_PHONE=0912-345-678
STORE_LINE_ID=@moonmoon

# Cron Job 驗證密鑰（Vercel 部署時自動設定）
# 本地測試可設定任意值，生產環境 Vercel 會自動處理
CRON_SECRET=your-cron-secret-here

# Admin 後台密碼（簡易保護）
ADMIN_PASSWORD=change-this-to-a-strong-password
# Admin 登入防暴力破解（可選；預設 5 次 / 15 分鐘，鎖 30 分鐘）
# ADMIN_AUTH_MAX_ATTEMPTS=5
# ADMIN_AUTH_WINDOW_MS=900000
# ADMIN_AUTH_LOCKOUT_MS=1800000

# n8n 訂單同步（可選）
# 用法：建立 n8n Webhook Trigger，將 URL 放入下方；網站在新訂單/狀態變更時會 POST
N8N_ORDER_WEBHOOK_URL=https://your-n8n-domain/webhook/moon-orders
# 建議設定簽章密鑰，n8n 端可用此值驗證 x-moon-signature (HMAC-SHA256)
N8N_ORDER_WEBHOOK_SECRET=replace-with-strong-secret

# Google Analytics 4 追蹤 ID（前端 gtag，選填）
# 取得方式：https://analytics.google.com → 管理 → 資料串流 → 評估 ID
NEXT_PUBLIC_GA4_ID=G-DM6F27KL8B

# 後台「站點成效」讀 GA4 Data API 用的 service account（與五站共用）
# 本地：放 JSON 於 ~/.credentials/kiwimu-service-account.json（程式預設路徑，免設變數）
#       或用 GOOGLE_APPLICATION_CREDENTIALS 指向該檔
# GOOGLE_APPLICATION_CREDENTIALS=/Users/you/.credentials/kiwimu-service-account.json
# 正式站(Vercel serverless 無檔案系統)：改用 inline JSON
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...完整內容...}
GA4_PROPERTY_ID=526838967

# LINE Pay（選填，未設定時程式會預設走 sandbox API URL）
LINEPAY_CHANNEL_ID=your-linepay-channel-id
LINEPAY_CHANNEL_SECRET=your-linepay-channel-secret
# Sandbox: https://sandbox-api-pay.line.me
# Production: https://api-pay.line.me
LINEPAY_API_URL=https://sandbox-api-pay.line.me

# 封測 / 正式站台根網址；LINE Pay confirmUrl / cancelUrl 會使用此值
NEXT_PUBLIC_SITE_URL=https://shop.kiwimu.com
# 若本機開發未設定 NEXT_PUBLIC_SITE_URL，僅允許這些 host 作為 fallback
PUBLIC_SITE_HOST_ALLOWLIST=shop.kiwimu.com
